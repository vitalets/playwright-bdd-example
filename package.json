{
  "name": "playwright-bdd-example",
  "version": "0.1.0",
  "scripts": {
    "test": "npx bddgen && npx playwright test",
    "report": "npx http-server ./cucumber-report -c-1 -a localhost -o index.html",
    "watch:bdd": "nodemon -w ./features -e feature,js,ts --exec \"npx bddgen\"",
    "watch:pw": "playwright test --ui",
    "watch": "run-p watch:*",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/node": "^20.9.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "http-server": "14.1.1",
    "nodemon": "^3.1.14",
    "npm-run-all": "^4.1.5",
    "playwright-bdd": "^9.2.0",
    "prettier": "^3.8.4",
    "prettier-plugin-gherkin": "^4.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  },
  "prettier": {
    "tabWidth": 2,
    "useTabs": false,
    "singleQuote": true,
    "printWidth": 100,
    "semi": true,
    "trailingComma": "all",
    "bracketSpacing": true,
    "plugins": [
      "prettier-plugin-gherkin"
    ]
  },
  "license": "MIT"
}
