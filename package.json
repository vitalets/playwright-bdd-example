{
  "name": "playwright-bdd-example",
  "version": "0.1.0",
  "scripts": {
    "test": "npx bddgen && npx playwright test",
    "report": "npx http-server ./cucumber-report -c-1 -a localhost -o index.html",
    "watch:bdd": "nodemon -w ./features -e feature,js,ts --exec \"npx bddgen\"",
    "watch:pw": "playwright test --ui",
    "watch": "run-p watch:*"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^20.9.4",
    "http-server": "14.1.1",
    "nodemon": "^3.1.14",
    "npm-run-all": "^4.1.5",
    "playwright-bdd": "^8.5.0",
    "prettier": "^3.8.1",
    "prettier-plugin-gherkin": "^3.1.3",
    "typescript": "^5.9.3"
  },
  "prettier": {
    "tabWidth": 2,
    "useTabs": false,
    "singleQuote": true,
    "printWidth": 100,
    "semi": true,
    "trailingComma": "all",
    "bracketSpacing": true,
    "plugins": [
      "prettier-plugin-gherkin"
    ]
  },
  "license": "MIT"
}
