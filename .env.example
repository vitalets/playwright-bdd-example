# --- Appium server ---
APPIUM_HOST=localhost
APPIUM_PORT=4723
APPIUM_PATH=/

# --- Mobile target (mobile-android / mobile-ios projects) ---
GAF_APPIUM_PLATFORM=android      # android | ios
GAF_APPIUM_PLATFORM_VERSION=14
GAF_APPIUM_DEVICE_NAME=Pixel_7_API_34
GAF_APPIUM_UDID=                  # leave empty for emulator
GAF_APP_NO_RESET=false

# --- App under test ---
GAF_APP_PACKAGE=com.vodafone.mpesa.tanzania.mat
GAF_APP_ACTIVITY=com.vodafone.mpesa.consumer.ui.launch.LaunchActivity
GAF_IOS_BUNDLE_ID=
GAF_APP_PATH=                     # local .apk / .app path OR bs://... for BrowserStack
GAF_APP_VERSION=                  # optional override; otherwise parsed from GAF_APP_PATH

# --- Test data + market routing ---
GAF_MARKET=tz                     # tz | mz | drc | lso
GAF_TEST_ENV=qa
GAF_TEST_DATA_DIR=src/config/markets

# --- Misc ---
GAF_EXPLICIT_WAIT_MS=30000
WDIO_LOG_LEVEL=warn
